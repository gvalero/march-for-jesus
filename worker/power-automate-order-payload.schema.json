{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marchforjesus.co.uk/schemas/mfj-merch-order-payload.schema.json",
  "title": "MFJ Belfast merch paid order payload",
  "type": "object",
  "required": ["profile", "order", "lines", "totals", "milestonesCrossed"],
  "properties": {
    "profile": {
      "type": "object",
      "required": ["name", "source", "site", "microsoftTenant"],
      "properties": {
        "name": { "const": "mfj-belfast-merch" },
        "source": { "const": "cloudflare-worker" },
        "site": { "const": "marchforjesus.co.uk" },
        "microsoftTenant": { "const": "allnations.ie" }
      },
      "additionalProperties": false
    },
    "order": {
      "type": "object",
      "required": [
        "id",
        "reservation_id",
        "stripe_checkout_session_id",
        "amount_total",
        "currency",
        "payment_status",
        "collection_status",
        "created_at"
      ],
      "properties": {
        "id": { "type": "string" },
        "reservation_id": { "type": "string" },
        "stripe_checkout_session_id": { "type": "string" },
        "stripe_payment_intent_id": { "type": ["string", "null"] },
        "customer_name": { "type": ["string", "null"] },
        "customer_email": { "type": ["string", "null"] },
        "amount_total": { "type": "integer", "minimum": 0 },
        "currency": { "type": "string" },
        "payment_status": { "type": "string" },
        "collection_status": { "type": "string" },
        "microsoft_sync_status": { "type": "string" },
        "created_at": { "type": "integer" }
      },
      "additionalProperties": true
    },
    "lines": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["order_id", "variant_id", "product_name", "colour", "size", "quantity", "unit_amount", "total_amount"],
        "properties": {
          "order_id": { "type": "string" },
          "variant_id": { "type": "string" },
          "product_name": { "type": "string" },
          "colour": { "type": "string" },
          "size": { "type": "string" },
          "quantity": { "type": "integer", "minimum": 1 },
          "unit_amount": { "type": "integer", "minimum": 1 },
          "total_amount": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": true
      }
    },
    "totals": {
      "type": "object",
      "required": ["itemCount", "amountTotal", "currency"],
      "properties": {
        "itemCount": { "type": "integer", "minimum": 1 },
        "amountTotal": { "type": "integer", "minimum": 1 },
        "currency": { "type": "string" }
      },
      "additionalProperties": false
    },
    "milestonesCrossed": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 10,
        "multipleOf": 10
      }
    }
  },
  "additionalProperties": false
}
